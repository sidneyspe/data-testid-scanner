{
  "name": "data-testid-scanner",
  "version": "2.0.0",
  "description": "Chrome/Edge extension que escaneia e lista todos os data-test-id de uma página em um sidebar interativo",
  "author": "Data-TestID Scanner Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/seu-usuario/data-testid-scanner.git"
  },
  "keywords": [
    "chrome-extension",
    "testing",
    "data-test-id",
    "qa",
    "web-testing",
    "automation"
  ],
  "scripts": {
    "dev": "echo 'Para desenvolvimento, carregue a extensão em chrome://extensions/'",
    "build": "npm run package:crx",
    "lint": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,html,css}\"",
    "test": "echo 'Abra test/test-page.html no navegador para testar'",
    "package:crx": "node scripts/build-crx.js"
  },
  "devDependencies": {
    "adm-zip": "^0.5.16",
    "chrome-extension-cli": "^1.5.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0"
  },
  "browserslist": [
    "chrome >= 88",
    "edge >= 88"
  ],
  "dependencies": {
    "concurrently": "^9.2.1",
    "wait-on": "^9.0.4"
  }
}
